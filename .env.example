# ============================================
# SUPACAMP — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# ============================================
# SUPABASE
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:postgres@db.your-project.supabase.co:5432/postgres

# ============================================
# NEXT.JS
# ============================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Supacamp

# ============================================
# AI VIDEO (Veo 3.1 Fast)
# ============================================
GOOGLE_AI_API_KEY=your-google-ai-api-key

# ============================================
# EMAIL (Resend)
# ============================================
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=noreply@supacamp.com

# ============================================
# ANALYTICS (Custom — no third party!)
# ============================================
# No third-party analytics keys needed
# Our analytics are self-hosted via Supabase

# ============================================
# OPTIONAL: DEVELOPMENT
# ============================================
# NEXT_PUBLIC_DEBUG=true
